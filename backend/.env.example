# ─── Firebase ───────────────────────────────────────────────────────────────
# Path to your downloaded Firebase service account JSON key
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
FIREBASE_PROJECT_ID=shopsyy-prod

# ─── Razorpay ────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxx
RAZORPAY_KEY_SECRET=xxxx
RAZORPAY_WEBHOOK_SECRET=xxxx

# ─── Cloudflare R2 ───────────────────────────────────────────────────────────
CF_R2_ACCESS_KEY_ID=xxxx
CF_R2_SECRET_ACCESS_KEY=xxxx
CF_R2_BUCKET_NAME=shopsyy-media
CF_R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
CF_R2_PUBLIC_URL=https://cdn.shopsyy.com   # Your custom domain or R2 public URL

# ─── Frontend (Vite) ─────────────────────────────────────────────────────────
# For local dev, point to the Firebase emulator:
# VITE_API_BASE_URL=http://localhost:5001/shopsyy-prod/asia-south1/api
# For production:
VITE_API_BASE_URL=https://api-xxxx.asia-south1.run.app/api

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=shopsyy-prod.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=shopsyy-prod
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_RAZORPAY_KEY_ID=rzp_live_xxxx

# ─── Optional: SMS fallback ──────────────────────────────────────────────────
SMS_PROVIDER=console
MSG91_API_KEY=
MSG91_TEMPLATE_ID=

# ─── Optional: Logistics ─────────────────────────────────────────────────────
DELHIVERY_API_KEY=
DELHIVERY_API_SECRET=

# ─── Optional: Email ─────────────────────────────────────────────────────────
SMTP_HOST=smtp.postmarkapp.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@shopsyy.com

# ─── Local dev only ──────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

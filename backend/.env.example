# Backend Environment Variables Template
# Copy this file to .env.local for local development

NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# Authentication (JWT)
JWT_SECRET=your_jwt_secret_min_64_chars_long
JWT_REFRESH_SECRET=your_refresh_secret_min_64_chars_long
ACCESS_TOKEN_EXPIRY=900
REFRESH_TOKEN_EXPIRY=604800

# Database & Cache (If using Postgres/Mongo/Redis instead of Firestore)
# MONGODB_URI=mongodb://localhost:27017/shopsyy_dev
# POSTGRES_URI=postgresql://user@localhost:5432/shopyng
# REDIS_URL=redis://localhost:6379

# Firebase Admin (Firestore Database)
FIREBASE_SERVICE_ACCOUNT_PATH=./path/to/your/firebase-adminsdk.json

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Third Party Services
SMS_PROVIDER=console
MSG91_API_KEY=
MSG91_TEMPLATE_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=

DELHIVERY_API_KEY=
DELHIVERY_API_SECRET=

# Cloud Storage (Images)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

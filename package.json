{
  "name": "shopyng",
  "private": true,
  "workspaces": [
    "packages/*",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm:dev:buyer\" \"npm:dev:vendor\" \"npm:dev:admin\" \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:buyer": "npm --workspace=buyer-app run dev",
    "dev:vendor": "npm --workspace=vendor-panel run dev",
    "dev:admin": "npm --workspace=admin-panel run dev",
    "dev:backend": "npm --workspace=backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "build": "npm-run-all --parallel build:buyer build:vendor build:admin build:backend build:frontend",
    "build:buyer": "npm --workspace=buyer-app run build",
    "build:vendor": "npm --workspace=vendor-panel run build",
    "build:admin": "npm --workspace=admin-panel run build",
    "build:backend": "npm --workspace=backend run build",
    "build:frontend": "npm --prefix frontend run build"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "npm-run-all": "^4.1.5"
  }
}
